{
  "expo": {
    "name": "CRM Proar",
    "slug": "crm-proar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "crm-proar",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "updates": {
        "enabled": false
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icons": ["./assets/notification-icon.png"],
          "color": "#ffffff"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.proar.crm",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Para ordenar las visitas del día por cercanía.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.proar.crm",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softInputMode": "adjustPan",
      "jsEngine": "hermes",
      "enableProguardInReleaseBuilds": true,
      "enableShrinkResourcesInReleaseBuilds": true,
      "permissions": ["ACCESS_FINE_LOCATION", "POST_NOTIFICATIONS"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2ce91658-de90-41b3-870a-ec5d0c0c54c9"
      }
    }
  }
}

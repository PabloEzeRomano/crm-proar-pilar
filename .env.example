EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Weekly email (Resend) — set as Edge Function secrets in Supabase dashboard
# Dashboard → Edge Functions → weekly-email → Secrets
RESEND_API_KEY=re_your_api_key
# Verified technical sender domain (set up in Resend → Domains)
MAIL_FROM_ADDRESS=crm@mail.your-domain.com
MAIL_FROM_NAME=Proar CRM

# Excel import script only
IMPORT_USER_ID=import-user-id
